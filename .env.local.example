# ─────────────────────────────────────────────────────────────────────────────
# Qwaam — environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase (client SDK — public, inlined into the browser bundle at build) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── App Check (reCAPTCHA v3) ──
# Site key for App Check. Leave blank locally to disable App Check init.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Set to 'true' in dev to print an App Check debug token in the browser console.
NEXT_PUBLIC_APPCHECK_DEBUG=false

# ── Firebase Admin SDK (server-only — full admin access, keep secret) ──
# Full service-account JSON as a single-line string.
FIREBASE_SERVICE_ACCOUNT_KEY=

# ── App / deep links ──
# Required in production (e.g. https://qwaam.net). Used for password-reset +
# cron renewal deep links. Falls back to the request host if unset.
NEXT_PUBLIC_APP_URL=

# ── Cron ──
# Guards GET /api/cron/subscription-reminders. Vercel attaches it automatically.
CRON_SECRET=

# ── Third-party services ──
RESEND_API_KEY=
SPOONACULAR_API_KEY=
NEXT_PUBLIC_ZEGO_APP_ID=
NEXT_PUBLIC_ZEGO_SERVER_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# ── E2E / Firebase emulators (local testing only) ──
# When 'true', the CLIENT SDK (firebase.ts) connects to the local emulators and
# skips App Check. Leave blank/false for normal dev and production.
# The Admin SDK auto-targets the emulators when FIRESTORE_EMULATOR_HOST /
# FIREBASE_AUTH_EMULATOR_HOST are set — those are injected automatically by
# `firebase emulators:exec`, so you normally do NOT set them by hand here.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
# ─────────────────────────────────────────────────────────────────────────────
